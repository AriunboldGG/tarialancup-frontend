rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to all collections for now
    // In production, you should restrict this based on authentication
    match /{document=**} {
      allow read, write: if true;
    }

    // Specific rules for team registrations
    match /basketball/{teamName}/registrations/{registrationId} {
      allow read, write: if true;
    }

  

    match /tennis/{teamName}/registrations/{registrationId} {
      allow read, write: if true;
    }

    match /darts/{teamName}/registrations/{registrationId} {
      allow read, write: if true;
    }

    match /other/{teamName}/registrations/{registrationId} {
      allow read, write: if true;
    }

    // Special orders collection
    match /special_quotes/{document=**} {
      allow read, write: if true;
    }
  }
}