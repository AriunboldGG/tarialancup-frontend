rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read access to all files
    match /{allPaths=**} {
      allow read;
    }

    // Allow write access for team photos
    match /team-photos/{year}/{teamName}/{fileName} {
      allow write: if request.auth != null ||
                   request.auth == null; // Allow anonymous uploads for now
      allow read;
    }

    // Allow write access for registrations
    match /registrations/{registrationId}/{fileName} {
      allow write: if request.auth != null ||
                   request.auth == null; // Allow anonymous uploads for now
      allow read;
    }

    // Default deny for other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}